# انسخ هذا الملف إلى .env واملأ القيم — التفاصيل في REQUIREMENTS.md

# ── قاعدة البيانات — PostgreSQL ──
DATABASE_URL="postgresql://user:pass@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:pass@host:5432/postgres"

# ── الأسرار (ولّدها: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))") ──
AUTH_SECRET=""
CRON_SECRET=""

# ── الدومين ──
NEXT_PUBLIC_SITE_URL="https://harajstation.com"

# ── Cloudflare R2 (تخزين الصور — اتركها فارغة للحفظ المحلي في التطوير) ──
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# ── Moyasar (الدفع — اتركها فارغة لوضع الشحن التجريبي) ──
MOYASAR_PUBLISHABLE_KEY=""
MOYASAR_SECRET_KEY=""
MOYASAR_WEBHOOK_SECRET=""

# ── Resend (البريد — اتركه فارغاً ليظهر رابط الاستعادة على الشاشة في التطوير) ──
RESEND_API_KEY=""
MAIL_FROM="حراج ستيشن <no-reply@harajstation.com>"

# ── Web Push (ولّدها: npx web-push generate-vapid-keys) ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# ── Google OAuth (اختياري — زر Google يعمل بوضع تجريبي بدونها) ──
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
